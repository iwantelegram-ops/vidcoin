# ══════════════════════════════════════════════════════════════════════════════
# .env — Konfigurasi Bot Premium Sharing Video (MongoDB Edition v4)
# ──────────────────────────────────────────────────────────────────────────────
# Cara pakai:
#   cp .env.example .env
#   nano .env        ← isi semua nilai yang WAJIB
#   python main.py
#
# Baris yang diawali # adalah komentar dan diabaikan.
# Jangan tambahkan spasi di sekitar tanda =
# ══════════════════════════════════════════════════════════════════════════════


# ── TELEGRAM API ──────────────────────────────────────────────────────────────
# Dapatkan dari: https://my.telegram.org/apps
# Buat aplikasi baru → salin App api_id dan App api_hash

API_ID=1234567
API_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── BOT TOKEN ─────────────────────────────────────────────────────────────────
# Dapatkan dari @BotFather di Telegram
# /newbot → ikuti langkah → salin token yang diberikan

BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── OWNER ─────────────────────────────────────────────────────────────────────
# User ID Telegram pemilik bot (angka, bukan username).
# Dapatkan dari @userinfobot — kirim /start ke bot itu.
# Owner memiliki akses penuh ke panel admin dan semua perintah.

OWNER_ID=123456789


# ══════════════════════════════════════════════════════════════════════════════
# IDENTITAS BOT
# ══════════════════════════════════════════════════════════════════════════════

# CODE_BOT — kode unik pengenal bot ini. WAJIB diisi dan jangan diubah
# setelah bot berjalan karena digunakan sebagai:
#   • Nama database MongoDB  → psv_bot_{CODE_BOT}
#   • Subfolder data lokal   → ~/psv_bot_data/{CODE_BOT}/
#
# Gunakan huruf kecil, angka, atau underscore. Tanpa spasi.
# Contoh: tokoku, jualvideo_v4, toko_dewasa_1

CODE_BOT=nama_bot_saya


# ══════════════════════════════════════════════════════════════════════════════
# DATABASE — MONGODB (opsional, tapi direkomendasikan)
# ══════════════════════════════════════════════════════════════════════════════
#
# Jika MONGO_URI diisi → MongoDB digunakan sebagai database utama.
# Jika MONGO_URI kosong → bot otomatis pakai SQLite lokal (lihat bagian SQLite).
#
# Nama database yang dibuat otomatis: psv_bot_{CODE_BOT}
#
# Format URI yang didukung:
#   MongoDB Atlas (cloud gratis):
#     mongodb+srv://username:password@cluster0.xxxxx.mongodb.net
#
#   MongoDB lokal:
#     mongodb://localhost:27017
#
#   MongoDB dengan auth lokal:
#     mongodb://username:password@localhost:27017
#
# Cara buat akun MongoDB Atlas gratis:
#   1. Daftar di https://cloud.mongodb.com
#   2. Buat cluster M0 (gratis)
#   3. Database Access → Add user → buat username & password
#   4. Network Access → Add IP → 0.0.0.0/0 (allow all)
#   5. Connect → Drivers → salin connection string
#   6. Ganti <password> dengan password yang dibuat di langkah 3

MONGO_URI=


# ══════════════════════════════════════════════════════════════════════════════
# DATABASE — SQLITE LOKAL (fallback / backup offline)
# ══════════════════════════════════════════════════════════════════════════════
#
# SQLite selalu aktif sebagai fallback, bahkan saat MongoDB digunakan.
# Saat MongoDB tidak dapat dijangkau, query otomatis dialihkan ke sini.
#
# SQLITE_PATH — path file database SQLite lokal.
#
# Format yang diterima (pilih salah satu):
#   1. Nama saja (tanpa / dan tanpa .db)
#      → Disimpan di ~/psv_bot_data/{nama}.db
#      Contoh: SQLITE_PATH=jual_video
#              Hasil: ~/psv_bot_data/jual_video.db
#
#   2. Path relatif ke home (~)
#      Contoh: SQLITE_PATH=~/psv_data/toko.db
#
#   3. Path absolut (cocok untuk Termux)
#      Contoh: SQLITE_PATH=/data/data/com.termux/files/home/psv/data.db
#
# Jika dikosongkan → ~/psv_bot_data/{CODE_BOT}/data.db  (default)
#
# ⚠️  Jangan ubah path ini setelah bot berjalan, kecuali saat migrasi.

SQLITE_PATH=


# ══════════════════════════════════════════════════════════════════════════════
# MIGRASI — IMPORT DATA DARI BOT LAMA (satu kali, opsional)
# ══════════════════════════════════════════════════════════════════════════════
#
# IMPORT_FROM — isi dengan path ke file .db dari versi bot sebelumnya
# yang ingin dipindahkan datanya ke bot baru ini.
#
# Cara kerja saat python main.py dijalankan pertama kali:
#   Tahap 1: data dari IMPORT_FROM  →  DB_PATH (SQLite lokal)
#             (selalu lokal ke lokal terlebih dahulu)
#   Tahap 2: data dari DB_PATH      →  MongoDB
#             (hanya jika MONGO_URI aktif)
#
#   Setelah tiap tahap selesai, file sumber dikosongkan otomatis.
#   Duplikat di MongoDB dihapus otomatis setelah import.
#
# Format sama dengan SQLITE_PATH — nama saja, ~, atau path absolut.
#
# Contoh:
#   IMPORT_FROM=~/jual_video/data.db
#   IMPORT_FROM=~/downloads/bot_lama/bot_data.db
#   IMPORT_FROM=/data/data/com.termux/files/home/old_bot/data.db
#
# ✅ Setelah migrasi berhasil → kosongkan baris ini atau hapus nilainya.
#    Aman jika tetap diisi — file kosong akan dilewati tanpa error.

IMPORT_FROM=
