# Salin: cp .env.example .env  lalu isi nilainya

# Dari https://my.telegram.org/apps
API_ID=1234567
API_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dari @BotFather
BOT_TOKEN=123456789:AAABBBCCC

# ID Telegram Anda (angka) — dapatkan dari @userinfobot
OWNER_ID=123456789

# ── CODE_BOT — WAJIB DIISI ──────────────────────────────────────────────────
# Kode unik pengenal bot ini.
CODE_BOT=nama_bot_saya

# ── MongoDB (OPSIONAL — PRIORITAS) ──────────────────────────────────────────
# Jika diisi, MongoDB digunakan sebagai database utama.
# Jika kosong, otomatis pakai SQLite lokal.
#
# Format: mongodb+srv://user:pass@cluster.mongodb.net
#         mongodb://localhost:27017
#
# Nama database MongoDB: psv_bot_{CODE_BOT}
MONGO_URI=

# ── SQLITE_PATH — Path database lokal (OPSIONAL) ────────────────────────────
# Format yang diterima:
#   1. Nama saja (tanpa / dan tanpa .db)  → ~/psv_bot_data/{nama}.db
#      Contoh: SQLITE_PATH=jual_video      menjadi ~/psv_bot_data/jual_video.db
#   2. Path relatif ke home
#      Contoh: SQLITE_PATH=~/psv_data/toko.db
#   3. Path absolut
#      Contoh: SQLITE_PATH=/data/data/com.termux/files/home/psv/data.db
#
# Jika kosong → ~/psv_bot_data/{CODE_BOT}/data.db
SQLITE_PATH=

# ── IMPORT_FROM — MIGRASI SATU KALI dari database bot LAMA ─────────────────
# Isi dengan path ke file .db dari bot lama yang ingin dipindahkan.
#
# Format sama dengan SQLITE_PATH di atas.
# Contoh:
#   IMPORT_FROM=~/jual_video/data.db
#   IMPORT_FROM=~/jual_video/bot_data.db
#
# Cara kerja saat python main.py dijalankan:
#   • Jika MONGO_URI aktif:
#       data dari IMPORT_FROM → MongoDB (upsert, tanpa duplikat)
#       file IMPORT_FROM dikosongkan setelah selesai
#   • Jika SQLite saja:
#       data dari IMPORT_FROM → DB_PATH (upsert, tanpa duplikat)
#       file IMPORT_FROM dikosongkan setelah selesai
#
# Setelah migrasi sukses, hapus atau biarkan baris ini kosong.
# Tidak berbahaya jika dibiarkan — file kosong akan dilewati.
IMPORT_FROM=
